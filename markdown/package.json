{
  "name": "markdown-editor",
  "version": "1.1.0",
  "description": "Minimal Markdown Editor",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build:macos": "electron-builder --macos --dir",
    "publish:github": "electron-builder --macos -p always"
  },
  "devDependencies": {
    "electron": "^7.0.0",
    "electron-builder": "^21.2.0"
  },
  "dependencies": {
    "electron-updater": "^4.2.0",
    "simplemde": "^1.11.2"
  },
  "build": {
    "appId": "com.my.markdown-editor",
    "publish": {
      "provider": "github",
      "owner": "TU_USUARIO_DE_GITHUB",
      "repo": "electron-updates"
    }
  }
}
